# Copia este archivo a .env y rellena los valores. NUNCA subas el .env real.

# Clave de OpenAI (necesaria para clasificación, chat, asesor y noticias).
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Clave de Google Gemini (opcional, clasificador alternativo).
GOOGLE_API_KEY=

# Rutas a los datos (por defecto, los de muestra ficticios de este repo).
EXTRACTED_JSON_PATH=data_muestra/pdfs_extracted.json
EXTRACTED_CODES_JSON_PATH=data_muestra/pdfs_extracted_codes.json

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Frontend
SERVE_FRONTEND=true
PUBLIC_API_BASE=http://localhost:8000
